# ─── AirNotes Backend v3 ──────────────────────────────────────────────────────

# 1. Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Your public backend URL (needed for Telegram to send webhook events)
#    On Render: https://your-app-name.onrender.com
#    On Railway: https://your-app-name.up.railway.app
#    Local dev: use ngrok → ngrok http 3001 → paste the https URL here
WEBHOOK_URL=https://your-app.onrender.com

# 3. JWT secret — any long random string
JWT_SECRET=change_this_to_a_long_random_string

# 4. App login password
APP_PASSWORD=Airflix@2003

# 5. Server port
PORT=3001

# 6. (Optional) Path to SQLite database file
#    On Render free tier: /tmp/airnotes.db (resets on redeploy — use Render Disk for persistence)
#    On paid Render: mount a disk at /data and set DB_PATH=/data/airnotes.db
DB_PATH=/tmp/airnotes.db

# ─── Frontend URL (for CORS reference, currently unused since we allow all) ───
FRONTEND_URL=https://your-frontend.vercel.app
